{
  "name": "eepl-site-v2",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "start": "npm run dev",
    "build:css": "npx tailwindcss -i ./src/input.css -o ./public/output.css",
    "watch:css": "npx tailwindcss -i ./src/input.css -o ./public/output.css --watch",
    "build:prod": "npx tailwindcss -i ./src/input.css -o ./public/output.css --minify"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "react-icons": "^5.2.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "vite": "^5.4.0"
  }
}
